// HR & ATS Platform - Comprehensive Database Schema
// Supports: App Admin, Company HR, Candidate roles
// AI-powered with OpenRouter integration

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION (NextAuth.js v4 compatible)
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String  @id @default(cuid())
  sessionToken String  @unique @map("session_token")
  userId       String  @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// CORE USER MODEL
// ============================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  COMPANY_ADMIN
  HR_MANAGER
  RECRUITER
  REVIEWER
  CANDIDATE
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String?
  image         String?
  role          UserRole @default(CANDIDATE)
  locale        String   @default("en")
  emailVerified DateTime? @map("email_verified")
  isActive      Boolean  @default(true) @map("is_active")
  twoFactorEnabled Boolean @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?  @map("two_factor_secret")  // Encrypted TOTP secret
  backupCodes      String?  @map("backup_codes")        // JSON array of hashed backup codes
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  accounts          Account[]
  sessions          Session[]
  candidateProfile  CandidateProfile?
  companyMemberships CompanyMember[]
  aiProviders       AIProvider[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  createdJobs       Job[]         @relation("JobCreator")
  interviewInterviewer InterviewAssignment[] @relation("Interviewer")
  assessmentResults AssessmentResult[]

  // Phase 3 relations
  comments        Comment[]
  commentReactions CommentReaction[]
  postedInternalJobs InternalJobPosting[] @relation("InternalJobPoster")

  @@map("users")
}

// ============================================
// COMPANY & TEAM
// ============================================

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  description String?
  website     String?
  industry    String?
  companySize String?  @map("company_size")
  location    String?
  verified    Boolean  @default(false)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Career Page (Feature 4)
  careerPageSlug  String?  @unique @map("career_page_slug")
  careerPageConfig String? @map("career_page_config") // JSON: colors, hero, sections

  // Relations
  members     CompanyMember[]
  jobs        Job[]
  stages      PipelineStage[]
  interviewKits InterviewKit[]
  emailTemplates EmailTemplate[]
  jobTemplates   JobTemplate[]
  bulkEmailCampaigns BulkEmailCampaign[]
  subscription   Subscription?
  biasAudits     BiasAudit[]
  fairHiringConfig FairHiringConfig?
  hiringWorkflows HiringWorkflow[]
  skillAssessments SkillAssessment[]
  sourcingCampaigns SourcingCampaign[]
  chatbotConfig    ChatbotConfig?

  // Phase 3 relations
  scorecardTemplates ScorecardTemplate[]
  applicationSources ApplicationSource[]
  integrationConfig  IntegrationConfig?

  // Stripe (Feature #10)
  stripeCustomerId String? @map("stripe_customer_id")

  @@map("companies")
}

model CompanyMember {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  companyId String   @map("company_id")
  role      UserRole
  title     String?
  joinedAt  DateTime @default(now()) @map("joined_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("company_members")
}

// ============================================
// CANDIDATE PROFILE
// ============================================

model CandidateProfile {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  phone           String?
  location        String?
  bio             String?
  resumeUrl       String?  @map("resume_url")
  resumeText      String?  @map("resume_text")
  skills          String?  // JSON array stored as string
  experienceYears Int?     @map("experience_years")
  currentTitle    String?  @map("current_title")
  linkedin        String?
  portfolio       String?
  availability    String?  @default("open")
  expectedSalary  String?  @map("expected_salary")
  isPublic        Boolean  @default(true) @map("is_public")
  publicSlug      String?  @unique @map("public_slug")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
  experiences  Experience[]
  educations   Education[]
  certifications Certification[]
  savedJobs    SavedJob[]
  eeoSurveys   EEOSurvey[]
  videoInterviewResponses VideoInterviewResponse[]
  candidateSkills CandidateSkill[]

  // GDPR (Feature 8)
  gdprConsentAt   DateTime? @map("gdpr_consent_at")
  gdprDataRequest Boolean  @default(false) @map("gdpr_data_request")

  @@map("candidate_profiles")
}

model Experience {
  id          String   @id @default(cuid())
  profileId   String   @map("profile_id")
  company     String
  title       String
  description String?
  startDate   String   @map("start_date")
  endDate     String?  @map("end_date")
  current     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  profile CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

model Education {
  id          String   @id @default(cuid())
  profileId   String   @map("profile_id")
  institution String
  degree      String
  field       String?
  startDate   String   @map("start_date")
  endDate     String?  @map("end_date")
  createdAt   DateTime @default(now()) @map("created_at")

  profile CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("educations")
}

model Certification {
  id        String   @id @default(cuid())
  profileId String   @map("profile_id")
  name      String
  issuer    String?
  date      String?
  createdAt DateTime @default(now()) @map("created_at")

  profile CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("certifications")
}

model SavedJob {
  id          String   @id @default(cuid())
  candidateId String   @map("candidate_id")
  jobId       String   @map("job_id")
  createdAt   DateTime @default(now()) @map("created_at")

  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobId])
  @@map("saved_jobs")
}

// ============================================
// JOBS & ATS
// ============================================

enum JobStatus {
  DRAFT
  OPEN
  PAUSED
  CLOSED
  ARCHIVED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  REMOTE
  HYBRID
}

model Job {
  id              String    @id @default(cuid())
  companyId       String    @map("company_id")
  createdById     String    @map("created_by_id")
  title           String
  slug            String    @unique
  description     String
  requirements    String?   // JSON array stored as string
  responsibilities String?  // JSON array stored as string
  benefits        String?   // JSON array stored as string
  jobType         JobType   @default(FULL_TIME) @map("job_type")
  status          JobStatus @default(DRAFT)
  salaryMin       Int?      @map("salary_min")
  salaryMax       Int?      @map("salary_max")
  salaryCurrency  String    @default("USD") @map("salary_currency")
  location        String?
  isRemote        Boolean   @default(false) @map("is_remote")
  experienceMin   Int?      @map("experience_min")
  experienceMax   Int?      @map("experience_max")
  skills          String?   // JSON array stored as string
  openings        Int       @default(1)
  deadline        DateTime?
  publishedAt     DateTime? @map("published_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Feature #17: Custom Hiring Workflows per Job
  customPipelineEnabled Boolean  @default(false) @map("custom_pipeline_enabled")
  customStageIds       String?  @map("custom_stage_ids") // JSON: array of PipelineStage IDs for this job

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User          @relation("JobCreator", fields: [createdById], references: [id])
  applications Application[]
  savedBy     SavedJob[]
  boardPostings JobBoardPosting[]
  internalPosting InternalJobPosting?
  workflowConfig  JobWorkflowConfig?

  @@map("jobs")
}

// ============================================
// PIPELINE & APPLICATIONS
// ============================================

model PipelineStage {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String
  order     Int
  color     String?  @default("#6366f1")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applicationStages ApplicationStage[]
  currentStageApplications Application[] @relation("CurrentStage")

  @@map("pipeline_stages")
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

model Application {
  id          String          @id @default(cuid())
  jobId       String          @map("job_id")
  candidateId String          @map("candidate_id")
  status      ApplicationStatus @default(APPLIED)
  currentStageId String?      @map("current_stage_id")
  coverLetter String?         @map("cover_letter")
  matchScore  Float?          @map("match_score")
  aiAnalysis  String?         @map("ai_analysis")
  source      String?         @default("direct")
  notes       String?
  appliedAt   DateTime        @default(now()) @map("applied_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // EEO Data (Feature 2) - voluntary demographic data
  eeoGender     String?         @map("eeo_gender")
  eeoEthnicity  String?         @map("eeo_ethnicity")
  eeoVeteran    String?         @map("eeo_veteran")
  eeoDisability String?         @map("eeo_disability")
  eeoDeclined   Boolean         @default(false) @map("eeo_declined")

  // Feature #16: Source Tracking & Attribution
  sourceId      String?  @map("source_id") // Link to ApplicationSource
  utmSource     String?  @map("utm_source")
  utmMedium     String?  @map("utm_medium")
  utmCampaign   String?  @map("utm_campaign")
  utmContent    String?  @map("utm_content")

  job             Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate       CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  currentStage    PipelineStage?   @relation("CurrentStage", fields: [currentStageId], references: [id])
  applicationStages ApplicationStage[]
  interviews      Interview[]
  offers          Offer[]

  @@unique([jobId, candidateId])
  @@map("applications")
}

model ApplicationStage {
  id            String   @id @default(cuid())
  applicationId String   @map("application_id")
  stageId       String   @map("stage_id")
  enteredAt     DateTime @default(now()) @map("entered_at")
  exitedAt      DateTime? @map("exited_at")
  notes         String?

  application Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  stage       PipelineStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@map("application_stages")
}

// ============================================
// INTERVIEWS
// ============================================

enum InterviewType {
  PHONE
  VIDEO
  ON_SITE
  ASYNC_VIDEO
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Interview {
  id              String          @id @default(cuid())
  applicationId   String          @map("application_id")
  type            InterviewType   @default(VIDEO)
  status          InterviewStatus @default(SCHEDULED)
  scheduledAt     DateTime?       @map("scheduled_at")
  durationMinutes Int             @default(30) @map("duration_minutes")
  location        String?
  meetingLink     String?         @map("meeting_link")
  feedback        String?
  rating          Int?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  application  Application          @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  assignments  InterviewAssignment[]

  @@map("interviews")
}

model InterviewAssignment {
  id          String   @id @default(cuid())
  interviewId String   @map("interview_id")
  interviewerId String @map("interviewer_id")
  scorecard   String?  // JSON stored as string
  notes       String?
  rating      Int?

  interview  Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewer User     @relation("Interviewer", fields: [interviewerId], references: [id], onDelete: Cascade)

  @@map("interview_assignments")
}

model InterviewKit {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  name        String
  description String?
  questions   String   // JSON array stored as string
  criteria    String?  // JSON stored as string
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("interview_kits")
}

// ============================================
// ASSESSMENTS
// ============================================

model Assessment {
  id              String   @id @default(cuid())
  companyId       String   @map("company_id")
  title           String
  description     String?
  questions       String   // JSON array stored as string
  timeLimitMinutes Int?    @map("time_limit_minutes")
  passingScore    Int?     @map("passing_score")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  results AssessmentResult[]

  @@map("assessments")
}

model AssessmentResult {
  id           String   @id @default(cuid())
  assessmentId String   @map("assessment_id")
  candidateId  String   @map("candidate_id")
  answers      String   // JSON stored as string
  score        Float?
  feedback     String?
  completedAt  DateTime @default(now()) @map("completed_at")

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  candidate  User       @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("assessment_results")
}

// ============================================
// AI CONFIGURATION (OpenRouter)
// ============================================

model AIProvider {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String   // e.g., "OpenRouter", "OpenAI", etc.
  apiKey    String   @map("api_key")
  baseUrl   String?  @map("base_url")
  isActive  Boolean  @default(true) @map("is_active")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  models AIModel[]

  @@map("ai_providers")
}

model AIModel {
  id         String   @id @default(cuid())
  providerId String   @map("provider_id")
  modelId    String   @map("model_id")   // e.g., "openai/gpt-4o", "anthropic/claude-3.5-sonnet"
  modelName  String   @map("model_name")  // Display name
  isActive   Boolean  @default(true) @map("is_active")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")

  provider AIProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("ai_models")
}

model AIUsageLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  modelId    String   @map("model_id")
  feature    String   // e.g., "resume_analysis", "match_scoring", "cover_letter"
  inputTokens  Int    @default(0) @map("input_tokens")
  outputTokens Int    @default(0) @map("output_tokens")
  duration   Int      @default(0) // ms
  success    Boolean  @default(true)
  error      String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("ai_usage_logs")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  message   String
  type      String   @default("info") // info, success, warning, error
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  action      String
  resource    String
  resourceId  String?  @map("resource_id")
  details     String?  // JSON stored as string
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ============================================
// OFFER MANAGEMENT
// ============================================

enum OfferStatus {
  DRAFT
  PENDING
  SENT
  ACCEPTED
  DECLINED
  WITHDRAWN
  EXPIRED
}

model Offer {
  id              String      @id @default(cuid())
  applicationId   String      @map("application_id")
  salary          Int?
  salaryCurrency  String      @default("USD") @map("salary_currency")
  equity          String?
  startDate       String?     @map("start_date")
  benefits        String?     // JSON stored as string
  conditions      String?     // JSON stored as string
  letterText      String?     @map("letter_text")
  status          OfferStatus @default(DRAFT)
  responseDeadline DateTime?  @map("response_deadline")
  respondedAt     DateTime?   @map("responded_at")
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  // Feature #12: E-Signatures
  signingToken       String?   @unique @map("signing_token")
  signingTokenExpiry DateTime? @map("signing_token_expiry")
  candidateSignedAt  DateTime? @map("candidate_signed_at")
  candidateSignature String?   @map("candidate_signature") // Base64 signature image or typed name
  companySignedAt    DateTime? @map("company_signed_at")
  companySignerId    String?   @map("company_signer_id") // Who signed on behalf of company
  signingStatus      String    @default("PENDING") @map("signing_status") // PENDING, SENT, CANDIDATE_SIGNED, COMPLETED, EXPIRED, DECLINED

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("offers")
}

// ============================================
// EMAIL TEMPLATES
// ============================================

model EmailTemplate {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  name        String
  subject     String
  body        String   // HTML with {{variable}} placeholders
  category    String   @default("general") // interview, rejection, offer, general, follow_up
  variables   String?  // JSON array of available variable names
  isDefault   Boolean  @default(false) @map("is_default")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("email_templates")
}

// ============================================
// CALENDAR & SCHEDULING
// ============================================

enum CalendarEventType {
  INTERVIEW
  MEETING
  CALL
  DEADLINE
  REMINDER
  OTHER
}

model CalendarEvent {
  id              String            @id @default(cuid())
  companyId       String?           @map("company_id")
  userId          String?           @map("user_id")
  title           String
  description     String?
  type            CalendarEventType @default(OTHER)
  startDate       DateTime          @map("start_date")
  endDate         DateTime?         @map("end_date")
  allDay          Boolean           @default(false) @map("all_day")
  location        String?
  meetingLink     String?           @map("meeting_link")
  reminderMinutes Int?              @map("reminder_minutes")
  color           String?           @default("#0d9488")
  applicationId   String?           @map("application_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@map("calendar_events")
}

// ============================================
// JOB TEMPLATES
// ============================================

model JobTemplate {
  id              String   @id @default(cuid())
  companyId       String   @map("company_id")
  name            String
  title           String
  description     String
  requirements    String?  // JSON array stored as string
  responsibilities String? // JSON array stored as string
  benefits        String?  // JSON array stored as string
  jobType         JobType  @default(FULL_TIME) @map("job_type")
  salaryMin       Int?     @map("salary_min")
  salaryMax       Int?     @map("salary_max")
  location        String?
  isRemote        Boolean  @default(false) @map("is_remote")
  skills          String?  // JSON array stored as string
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("job_templates")
}

// ============================================
// ACTIVITY LOG (per-candidate timeline)
// ============================================

enum ActivityType {
  CALL
  EMAIL
  MEETING
  INTERVIEW
  NOTE
  STATUS_CHANGE
  OFFER
  ASSESSMENT
}

model Activity {
  id          String       @id @default(cuid())
  candidateId String       @map("candidate_id")
  userId      String       @map("user_id")
  type        ActivityType
  title       String
  description String?
  applicationId String?    @map("application_id")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("activities")
}

// ============================================
// EEO / DEI DATA (Feature 2)
// ============================================

enum EEOGender {
  MALE
  FEMALE
  NON_BINARY
  OTHER
  PREFER_NOT_TO_SAY
}

enum EEOEthnicity {
  HISPANIC_OR_LATINO
  WHITE
  BLACK_OR_AFRICAN_AMERICAN
  ASIAN
  NATIVE_HAWAIIAN_OR_PACIFIC_ISLANDER
  AMERICAN_INDIAN_OR_ALASKA_NATIVE
  TWO_OR_MORE_RACES
  OTHER
  PREFER_NOT_TO_SAY
}

model EEOSurvey {
  id              String   @id @default(cuid())
  candidateId     String   @map("candidate_id")
  applicationId   String?  @map("application_id")
  gender          String?
  ethnicity       String?
  veteranStatus   String?  @map("veteran_status")  // yes, no, prefer_not_to_say
  disabilityStatus String? @map("disability_status") // yes, no, prefer_not_to_say
  declinedToSelfIdentify Boolean @default(false) @map("declined_to_self_identify")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("eeo_surveys")
}

// ============================================
// BULK EMAIL / MASS MESSAGING (Feature 7)
// ============================================

enum BulkEmailStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

model BulkEmailCampaign {
  id          String         @id @default(cuid())
  companyId   String         @map("company_id")
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  subject     String
  body        String         // HTML body with {{variable}} placeholders
  templateId  String?        @map("template_id")
  status      BulkEmailStatus @default(DRAFT)
  recipientCount Int         @default(0) @map("recipient_count")
  sentCount   Int            @default(0) @map("sent_count")
  openedCount Int            @default(0) @map("opened_count")
  clickedCount Int           @default(0) @map("clicked_count")
  bouncedCount Int           @default(0) @map("bounced_count")
