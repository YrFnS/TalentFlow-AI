  endTime       String   // "17:00"
  slotDuration  Int      @default(60) @map("slot_duration") // minutes
  bufferBetween Int      @default(15) @map("buffer_between") // minutes between slots
  isActive      Boolean  @default(true) @map("is_active")
  timezone      String   @default("UTC")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("interviewer_availability")
}

// ============================================
// FEATURE #8: MOBILE-OPTIMIZED APPLY FLOW
// ============================================

model QuickApplyConfig {
  id               String  @id @default(cuid())
  jobId            String  @unique @map("job_id")
  enableOneClick   Boolean @default(false) @map("enable_one_click")
  enableQuickApply Boolean @default(true) @map("enable_quick_apply")
  minFields        String  @default("[\"name\",\"email\",\"resume\"]") @map("min_fields") // JSON
  enableTextApply  Boolean @default(false) @map("enable_text_apply")
  textApplyCode    String? @unique @map("text_apply_code")
  qrCodeUrl        String? @map("qr_code_url")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("quick_apply_configs")
}

model TextApplySession {
  id          String   @id @default(cuid())
  jobId       String   @map("job_id")
  phoneNumber String   @map("phone_number")
  status      String   @default("STARTED") // STARTED, LINK_SENT, APPLIED, EXPIRED
  applyLink   String   @map("apply_link")
  createdAt   DateTime @default(now()) @map("created_at")
  expiresAt   DateTime @map("expires_at")

  @@map("text_apply_sessions")
}

// ============================================
// FEATURE #9: IN-APP RECRUITING CHATBOT
// ============================================

model ChatbotConfig {
  id                 String  @id @default(cuid())
  companyId          String  @unique @map("company_id")
  welcomeMessage     String  @default("Hi! I'm your AI recruiting assistant. How can I help?") @map("welcome_message")
  personality        String  @default("professional") // professional, friendly, casual
  enabledFeatures    String  @default("[\"job_search\",\"application_status\",\"faq\",\"interview_prep\"]") @map("enabled_features") // JSON
  knowledgeBase      String? @map("knowledge_base") // JSON: company FAQ, policies, benefits
  isActive           Boolean @default(true) @map("is_active")
  leadCaptureEnabled Boolean @default(true) @map("lead_capture_enabled")
  leadCaptureFields  String  @default("[\"name\",\"email\",\"phone\"]") @map("lead_capture_fields") // JSON
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("chatbot_configs")
}

// ============================================
// FEATURE #10: STRIPE PAYMENT INTEGRATION
// ============================================

// Stripe fields added to existing Subscription, Invoice, Company, Plan models
// via separate ALTER statements below. New model for webhook events:

model StripeWebhookEvent {
  id             String   @id @default(cuid())
  stripeEventId  String   @unique @map("stripe_event_id")
  type           String   // checkout.session.completed, invoice.paid, etc.
  data           String   // JSON: full event data
  processed      Boolean  @default(false) @map("processed")
  processedAt    DateTime? @map("processed_at")
  error          String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("stripe_webhook_events")
}

// ============================================
// FEATURE #11: STRUCTURED INTERVIEW SCORECARDS
// ============================================

model ScorecardTemplate {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  name        String   // e.g., "Engineering Interview Scorecard"
  criteria    String   // JSON: [{ name, description, weight, ratingLevels }]
  totalWeight Int      @default(100) @map("total_weight")
  isDefault   Boolean  @default(false) @map("is_default")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("scorecard_templates")
}

// ============================================
// FEATURE #13: INTERNAL MOBILITY / INTERNAL JOB BOARD
// ============================================

model InternalJobPosting {
  id              String   @id @default(cuid())
  jobId           String   @unique @map("job_id")
  companyId       String   @map("company_id")
  postedById      String   @map("posted_by_id")
  isInternalOnly  Boolean  @default(true) @map("is_internal_only")
  minTenureMonths Int      @default(6) @map("min_tenure_months")
  notifyEmployees Boolean  @default(true) @map("notify_employees")
  internalNotes   String?  @map("internal_notes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  job       Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  postedBy  User @relation("InternalJobPoster", fields: [postedById], references: [id])
  applications InternalApplication[]

  @@map("internal_job_postings")
}

model InternalApplication {
  id              String   @id @default(cuid())
  jobId           String   @map("job_id")
  candidateId     String   @map("candidate_id") // The employee (has CandidateProfile)
  currentRoleId   String?  @map("current_role_id")
  managerNotified Boolean  @default(false) @map("manager_notified")
  managerApproved Boolean?  @map("manager_approved")
  status          String   @default("PENDING") @map("status") // PENDING, MANAGER_APPROVED, INTERVIEW, OFFERED, HIRED, REJECTED
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  internalJobPosting InternalJobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("internal_applications")
}

// ============================================
// FEATURE #15: REAL-TIME COLLABORATION (COMMENTS/MENTIONS)
// ============================================

model Comment {
  id          String    @id @default(cuid())
  entityType  String    // "APPLICATION", "CANDIDATE", "JOB", "INTERVIEW"
  entityId    String    @map("entity_id") // ID of the entity
  authorId    String    @map("author_id")
  parentId    String?   @map("parent_id") // For threaded replies
  content     String
  mentions    String?   // JSON: array of mentioned userIds
  isPinned    Boolean   @default(false) @map("is_pinned")
  isResolved  Boolean   @default(false) @map("is_resolved")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  author  User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")
  reactions CommentReaction[]

  @@map("comments")
}

model CommentReaction {
  id        String  @id @default(cuid())
  commentId String  @map("comment_id")
  userId    String  @map("user_id")
  emoji     String  // "thumbs_up", "heart", "celebration", etc.
  createdAt DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@map("comment_reactions")
}

// ============================================
// FEATURE #16: SOURCE TRACKING & ATTRIBUTION
// ============================================

model ApplicationSource {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  name        String   // "LinkedIn", "Referral", "Career Page", "Indeed"
  type        String   // "JOB_BOARD", "REFERRAL", "SOCIAL", "CAREER_PAGE", "AGENCY", "DIRECT", "OTHER"
  isDefault   Boolean  @default(false) @map("is_default")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("application_sources")
}

// ============================================
// FEATURE #17: CUSTOM HIRING WORKFLOWS PER JOB
// ============================================

model JobWorkflowConfig {
  id               String   @id @default(cuid())
  jobId            String   @unique @map("job_id")
  stageIds         String   @map("stage_ids") // JSON: ordered array of stage IDs
  autoAdvanceRules String?  @map("auto_advance_rules") // JSON: [{ fromStage, toStage, condition }]
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_workflow_configs")
}

// ============================================
// FEATURE #18: SLACK/TEAMS INTEGRATION
// ============================================

model IntegrationConfig {
  id              String   @id @default(cuid())
  companyId       String   @unique @map("company_id")
  slackEnabled    Boolean  @default(false) @map("slack_enabled")
  slackWebhookUrl String?  @map("slack_webhook_url")
  slackChannel    String?  @map("slack_channel")
  teamsEnabled    Boolean  @default(false) @map("teams_enabled")
  teamsWebhookUrl String?  @map("teams_webhook_url")
  teamsChannel    String?  @map("teams_channel")
  events          String   @default("[\"application.created\",\"interview.scheduled\",\"offer.sent\"]") // JSON: events to notify on
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("integration_configs")
}
